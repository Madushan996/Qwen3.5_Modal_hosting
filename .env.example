# After running: modal deploy modal_app.py
# copy the URLs printed in the output and paste them below,
# then rename this file to .env

# The /chat endpoint URL  (shown as "chat" web endpoint in deploy output)
MODAL_CHAT_URL=https://YOUR-WORKSPACE--gemma-4-e4b-chat-gemmaservice-chat.modal.run

# The /health endpoint URL  (optional — enables the status check)
MODAL_HEALTH_URL=https://YOUR-WORKSPACE--gemma-4-e4b-chat-gemmaservice-health.modal.run
